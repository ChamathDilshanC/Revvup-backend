# Supabase project settings — copy to .env and fill in real values.
# Find these in Supabase Dashboard -> Project Settings -> API.

# e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Legacy tab: "anon public" — safe for clients / fallback reads
SUPABASE_ANON_KEY=

# Legacy tab: "service_role secret" — REQUIRED for bike CRUD + image upload (server only)
# Either env name works on Vercel:
SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# New Supabase dashboard keys (sb_publishable_ / sb_secret_) — not used by this backend yet;
# keep using legacy JWT keys above for SUPABASE_ANON_KEY and SUPABASE_SERVICE_KEY.

# Storage bucket name for bike images (create it in Supabase Storage).
SUPABASE_BUCKET=bike-images

# --- Showroom-owner approval + email --------------------------------------
# Developer who approves/rejects new showroom owners (receives the email).
DEVELOPER_EMAIL=dilshancolonne123@gmail.com

# Public base URL of THIS backend (used to build approve/reject links in email).
# Local dev:
APP_BASE_URL=http://localhost:8000
# Vercel production (set in dashboard — required for correct Approve/Reject links):
# APP_BASE_URL=https://revvup-backend.vercel.app
# On Vercel, if this is still localhost, the app auto-uses https://$VERCEL_URL instead.

# SMTP for sending the HTML approval email.
# Gmail example: host=smtp.gmail.com, port=587, user=<gmail>, password=<App Password>
# (Create an App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
